		{
			"name": "Step 1 - Create Lab Order",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					},
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"patient_id\": \"{{patient_id}}\",\n    \"doctor_id\": \"{{doctor_id}}\",\n    \"order_type\": \"LAB\",\n    \"priority\": \"ROUTINE\",\n    \"clinical_notes\": \"Routine complete blood count check.\",\n    \"context_type\": \"OPD_VISIT\",\n    \"context_id\": \"99999999-9999-9999-9999-999999999999\",\n    \"source_module\": \"OPD\",\n    \"encounter_type\": \"CONSULTATION\",\n    \"lab_items\": [\n        {\n            \"test_id\": \"{{test_id}}\",\n            \"notes\": \"Check Hb levels\"\n        }\n    ]\n}"
				},
				"url": {
					"raw": "{{base_url}}/diagnostic-orders",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"diagnostic-orders"
					]
				},
				"description": "Create a new lab diagnostics order. The status of the order items will default to 'PENDING'. Ensure that patient_id, doctor_id, and test_id are replaced with valid database UUIDs."
			},
			"response": []
		},
		{
			"name": "Step 1b - View Lab Order",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
