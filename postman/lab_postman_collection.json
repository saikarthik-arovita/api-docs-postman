					"host": [
						"{{base_url}}"
					],
					"path": [
						"diagnostic-orders",
						"lab",
						"{{order_id}}"
					]
				},
				"description": "Retrieves a full lab order view including the order header (with patient name, MRN, doctor name), all lab items enriched with test details (test name, code, category, specimen type, price, sample collector name), and the latest lab result per item (with entered-by and validated-by names). Requires 'diagnostics:order:view' permission."
			},
			"response": []
		},
