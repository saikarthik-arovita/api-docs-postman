			"description": "Aggregate and analytics endpoints for compliance, security switches, audit logs, and reports.",
			"item": [
				{
					"name": "GET System Audit Logs Overview",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/admin/compliance/audit-overview?page=1&page_size=10&severity=CRITICAL&user=John&module=auth&fromDate=2026-07-01T00:00:00Z&toDate=2026-07-08T23:59:59Z",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"admin",
								"compliance",
								"audit-overview"
							],
							"query": [
								{
									"key": "page",
									"value": "1",
									"description": "Page number for pagination"
								},
								{
									"key": "page_size",
									"value": "10",
									"description": "Results per page"
								},
								{
									"key": "severity",
									"value": "CRITICAL",
									"description": "Filter by severity (CRITICAL, WARNING, INFO)"
								},
								{
									"key": "user",
									"value": "John",
									"description": "Full name or email substring search for user"
								},
								{
									"key": "module",
									"value": "auth",
									"description": "Filter by system module action"
								},
								{
									"key": "fromDate",
									"value": "2026-07-01T00:00:00Z",
									"description": "Filter logs starting from date"
								},
								{
									"key": "toDate",
									"value": "2026-07-08T23:59:59Z",
									"description": "Filter logs ending at date"
								}
							]
						},
						"description": "Returns high-level metric cards (total events, critical alerts, warnings, failed login attempts) and a paginated list of audit events matching filters."
					},
					"response": []
				},
