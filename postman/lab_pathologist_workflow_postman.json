						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"status\": \"APPROVED\",\n  \"remarks\": \"Verified report parameters. Signed by pathologist.\",\n  \"digitalSignature\": true\n}"
