{
  "info": {
    "name": "HMS - Pharmacy Staff Account Creation & Onboarding Flow",
    "description": "Complete flow to create a new Pharmacy Staff Account (Pharmacy Manager or Pharmacist), perform first-time login challenge, complete self-onboarding (schedule, payroll, bank, tax, license, ID proof, training completion), verify compliance documents, and activate the profile.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "auth_base_url",
      "value": "https://your-api-gateway-url.amazonaws.com/prod",
      "type": "string"
    },
    {
      "key": "admin_access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "staff_access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "staff_user_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "staff_employee_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "staff_temp_password",
      "value": "",
      "type": "string"
    },
    {
      "key": "staff_new_password",
      "value": "PharmStaff@Arovita2026!",
      "type": "string"
    },
    {
      "key": "challenge_session",
      "value": "",
      "type": "string"
    },
    {
      "key": "pharmacy_license_doc_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "id_proof_doc_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "training_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "01 - Admin: Login & Create Pharmacy Staff",
      "item": [
        {
          "name": "1. Admin Login",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin@arovita.com\",\n  \"password\": \"AdminSecurePassword@2026\",\n  \"device_info\": \"Postman Admin\"\n}"
            },
            "url": {
              "raw": "{{auth_base_url}}/auth/login",
              "host": [
                "{{auth_base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success && jsonData.data && jsonData.data.tokens) {",
                  "    pm.collectionVariables.set('admin_access_token', jsonData.data.tokens.access_token);",
                  "    console.log('Admin login successful. Access Token captured.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "2. Create Pharmacy Staff Account",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{admin_access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Vikram Seth\",\n  \"email\": \"vikram.pharmacist@arovita.com\",\n  \"phone\": \"+919876543219\",\n  \"role\": \"PHARMACIST\",\n  \"qualification\": \"B.Pharm\",\n  \"gender\": \"MALE\",\n  \"date_of_birth\": \"1992-05-15\"\n}"
            },
            "url": {
              "raw": "{{auth_base_url}}/auth/staff",
              "host": [
                "{{auth_base_url}}"
              ],
              "path": [
                "auth",
                "staff"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success && jsonData.data) {",
                  "    pm.collectionVariables.set('staff_user_id', jsonData.data.id);",
                  "    pm.collectionVariables.set('staff_employee_id', jsonData.data.employee_id);",
                  "    pm.collectionVariables.set('staff_temp_password', jsonData.data.temp_password);",
                  "    console.log('Pharmacy Staff Created: ID=' + jsonData.data.id + ', TempPass=' + jsonData.data.temp_password);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02 - Staff: First-Time Login Challenge",
      "item": [
        {
          "name": "1. Initiate Login (Temp Password)",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{staff_employee_id}}\",\n  \"password\": \"{{staff_temp_password}}\",\n  \"device_info\": \"Postman Staff Client\"\n}"
            },
            "url": {
              "raw": "{{auth_base_url}}/auth/login",
              "host": [
                "{{auth_base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.session) {",
                  "    pm.collectionVariables.set('challenge_session', jsonData.data.session);",
                  "    console.log('Challenge session captured.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "2. Complete Password Challenge",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{staff_employee_id}}\",\n  \"session\": \"{{challenge_session}}\",\n  \"new_password\": \"{{staff_new_password}}\"\n}"
            },
            "url": {
              "raw": "{{auth_base_url}}/auth/new-password",
              "host": [
                "{{auth_base_url}}"
              ],
              "path": [
                "auth",
                "new-password"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success && jsonData.data && jsonData.data.tokens) {",
                  "    pm.collectionVariables.set('staff_access_token', jsonData.data.tokens.access_token);",
                  "    console.log('Permanent password set. Staff Access Token captured.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
