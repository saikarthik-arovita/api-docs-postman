    {
      "name": "Prescription Management",
      "item": [
        {
          "name": "Create Prescription",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.success && response.data) {",
                  "    pm.collectionVariables.set('prescription_id', response.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patient_id\": \"{{patient_id}}\",\n  \"doctor_id\": \"00000000-0000-0000-0000-000000000002\",\n  \"context_type\": \"OPD_VISIT\",\n  \"context_id\": \"00000000-0000-0000-0000-000000000003\",\n  \"source_module\": \"OPD\",\n  \"encounter_type\": \"CONSULTATION\",\n  \"items\": [\n    {\n      \"medicine_id\": \"{{medicine_id}}\",\n      \"route\": \"ORAL\",\n      \"dosage\": \"1 capsule\",\n      \"frequency\": \"TDS\",\n      \"duration_days\": 5,\n      \"with_food\": true\n    }\n  ],\n  \"allergy_checked\": true,\n  \"interaction_checked\": true,\n  \"notes\": \"Prescription created from Postman\"\n}"
            },
