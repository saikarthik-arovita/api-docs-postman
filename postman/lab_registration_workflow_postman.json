		{
			"key": "baseUrl",
			"value": "http://localhost:3000",
			"type": "string"
		},
		{
			"key": "authToken",
			"value": "your_access_token",
			"type": "string"
		},
		{
			"key": "registrationId",
			"value": "registration-uuid-here",
			"type": "string"
		},
		{
			"key": "orderId",
			"value": "order-uuid-here",
			"type": "string"
		}
	]
}
